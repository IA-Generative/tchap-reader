# ── Tchap/Matrix connection (legacy — optionnel en mode multi-tenant) ──
TCHAP_HOMESERVER_URL=https://matrix.agent.tchap.gouv.fr
TCHAP_ACCESS_TOKEN=your_access_token_here
TCHAP_USER_ID=@bot:agent.tchap.gouv.fr
TCHAP_DEVICE_ID=OWUI_BOT

# ── Storage ──
TCHAP_STORE_PATH=/app/data/tchap.db

# ── Allowed rooms (legacy — ignoré en mode multi-tenant) ──
TCHAP_ALLOWED_ROOM_IDS=!roomid1:agent.tchap.gouv.fr,!roomid2:agent.tchap.gouv.fr

# ── Defaults ──
TCHAP_DEFAULT_WINDOW_HOURS=168
TCHAP_API_RATE_LIMIT_PER_SEC=1.0
TCHAP_MAX_MESSAGES_PER_ANALYSIS=1000
TCHAP_MAX_WINDOW_DAYS=30

# ── Privacy ──
TCHAP_ANONYMIZE_OUTPUT=true

# ── Logging ──
TCHAP_LOG_LEVEL=INFO

# ── Multi-tenant (v0.2) ──
# URL interne d'Open WebUI pour vérifier les groupes
OPENWEBUI_BASE_URL=http://open-webui:8080
# URL publique du service pour le callback SSO
SSO_CALLBACK_BASE_URL=http://tchap-reader:8087
